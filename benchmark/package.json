{
  "name": "appwrite-arena-benchmark",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "bun run src/index.ts",
    "bench:with-skills": "bun run src/index.ts --mode with-skills",
    "bench:without-skills": "bun run src/index.ts --mode without-skills",
    "bench:all": "bun run src/index.ts --mode with-skills && bun run src/index.ts --mode without-skills"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
